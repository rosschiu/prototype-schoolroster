{
  "name": "prototype-schoolroster",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "dev:api": "npm run dev --workspace @prototype-schoolroster/api",
    "dev:web": "npm run dev --workspace @prototype-schoolroster/web",
    "dev:api:pglocal": "DATABASE_URL=postgres://nexus:nexus@127.0.0.1:5432/nexus2 DATABASE_SCHEMA=schoolroster_dev npm run dev --workspace @prototype-schoolroster/api",
    "test:api:pglocal": "DATABASE_URL=postgres://nexus:nexus@127.0.0.1:5432/nexus2 npm test --workspace @prototype-schoolroster/api",
    "validate:pglocal": "DATABASE_URL=postgres://nexus:nexus@127.0.0.1:5432/nexus2 DATABASE_SCHEMA=schoolroster_val18 node scripts/validate-pglocal.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "fastify": "^5.8.5"
  }
}
